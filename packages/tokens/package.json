{
  "name": "@hopline/ux4g-tokens",
  "version": "0.3.1",
  "description": "UX4G design tokens: CSS variables, fonts, interaction layer, and a typed theme object. Unofficial community packaging of UX4G (© NeGD · MeitY · ux4g.gov.in).",
  "license": "MIT",
  "author": "Hopline (https://hopline.co)",
  "homepage": "https://ux4g.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hopline-AI/ux4g.git",
    "directory": "packages/tokens"
  },
  "bugs": "https://github.com/Hopline-AI/ux4g/issues",
  "keywords": ["ux4g", "design-system", "design-tokens", "css-variables", "theme", "india", "government", "accessibility", "wcag"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": ["styles.css", "tokens", "dist"],
  "exports": {
    "./styles.css": "./styles.css",
    "./tokens/*": "./tokens/*",
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js",
      "require": "./dist/theme.cjs"
    }
  },
  "scripts": {
    "gen:theme": "tsx scripts/gen-theme.ts",
    "build": "pnpm gen:theme && tsup",
    "typecheck": "pnpm gen:theme && tsc --noEmit",
    "test": "pnpm gen:theme && vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
