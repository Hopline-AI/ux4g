{
  "name": "@hopline/ux4g-react",
  "version": "0.2.1",
  "description": "Zero-dependency, CSS-variable-themed React components for UX4G, India's government design system. Unofficial community packaging (© NeGD · MeitY · ux4g.gov.in).",
  "license": "MIT",
  "author": "Hopline (https://hopline.co)",
  "homepage": "https://ux4g.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hopline-AI/ux4g.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/Hopline-AI/ux4g/issues",
  "keywords": ["ux4g", "design-system", "react", "components", "ui", "india", "government", "accessibility", "wcag", "zero-dependency"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": { "react": ">=18" },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
