---
import Base from "../layouts/Base.astro";

// AEO: FAQ + HowTo structured data so answer engines can quote the install steps.
const installJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      name: "Install UX4G React components",
      description: "Add the UX4G community packaging to a React project from npm.",
      step: [
        { "@type": "HowToStep", position: 1, name: "Add the packages", text: "Run: pnpm add @hopline/ux4g-react @hopline/ux4g-tokens" },
        { "@type": "HowToStep", position: 2, name: "Import the tokens stylesheet", text: "Import \"@hopline/ux4g-tokens/styles.css\" once at the root of your app." },
        { "@type": "HowToStep", position: 3, name: "Use a component", text: "Import { Button } from \"@hopline/ux4g-react\" and render it anywhere." },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "How do I install UX4G in a React app?",
          acceptedAnswer: { "@type": "Answer", text: "Install both packages with pnpm add @hopline/ux4g-react @hopline/ux4g-tokens, import the tokens stylesheet once at your app root, then import components from @hopline/ux4g-react." },
        },
        {
          "@type": "Question",
          name: "Do I need to import a stylesheet?",
          acceptedAnswer: { "@type": "Answer", text: "Yes. Import \"@hopline/ux4g-tokens/styles.css\" exactly once at your app root. Without it, components render unstyled." },
        },
        {
          "@type": "Question",
          name: "Can I copy a single component instead of installing the package?",
          acceptedAnswer: { "@type": "Answer", text: "Yes. Use the shadcn CLI: npx shadcn add https://ux4g.pages.dev/r/button.json. You own the copied source." },
        },
        {
          "@type": "Question",
          name: "What licence is UX4G community packaging under?",
          acceptedAnswer: { "@type": "Answer", text: "MIT, free and open source. UX4G itself is © NeGD · MeitY, Government of India." },
        },
      ],
    },
  ],
};
---

<Base title="Install" description="Add UX4G to a React project two ways: install @hopline/ux4g-react and @hopline/ux4g-tokens from npm, or copy a single component's source with the shadcn CLI. Import the tokens stylesheet once at your app root.">
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <span class="eyebrow">Install</span>
      <h1 class="h-display" style="font-size: clamp(36px, 5vw, var(--headline-1-size)); max-width: 20ch;">
        Add UX4G to your project
      </h1>
      <p class="lead" style="margin-top: var(--space-5);">
        Two paths: install the npm packages, or copy a single component's source
        into your repo with the shadcn registry. Both rely on the same design tokens.
      </p>

      <!-- npm -->
      <div class="stack-lg" style="margin-top: var(--space-10);">
        <div class="stack">
          <h2 class="h-section">1. npm package</h2>
          <p style="color: var(--color-text-muted);">
            Install the React components and the tokens package side by side.
          </p>
          <pre class="code-block"><code><span class="tok-keyword">pnpm</span> add @hopline/ux4g-react @hopline/ux4g-tokens</code></pre>

          <p style="color: var(--color-text-muted);">
            Import the tokens stylesheet once, at the root of your app. This loads the
            fonts, colours, type scale and interaction layer for every component.
          </p>
          <pre class="code-block"><code><span class="tok-keyword">import</span> <span class="tok-string">"@hopline/ux4g-tokens/styles.css"</span>;</code></pre>

          <p style="color: var(--color-text-muted);">
            Now import and use components anywhere.
          </p>
          <pre class="code-block"><code><span class="tok-keyword">import</span> &#123; Button &#125; <span class="tok-keyword">from</span> <span class="tok-string">"@hopline/ux4g-react"</span>;

<span class="tok-keyword">export function</span> Apply() &#123;
  <span class="tok-keyword">return</span> &lt;Button variant=<span class="tok-string">"primary"</span>&gt;Submit application&lt;/Button&gt;;
&#125;</code></pre>
        </div>

        <!-- shadcn -->
        <div class="stack">
          <h2 class="h-section">2. shadcn registry</h2>
          <p style="color: var(--color-text-muted);">
            Prefer to own the source? Pull a single component into your repository
            with the shadcn CLI. From a local checkout of this repo:
          </p>
          <pre class="code-block"><code><span class="tok-keyword">npx</span> shadcn add ./registry/r/button.json</code></pre>

          <p style="color: var(--color-text-muted);">
            Or straight from the hosted registry (live now):
          </p>
          <pre class="code-block"><code><span class="tok-keyword">npx</span> shadcn add https://ux4g.pages.dev/r/button.json</code></pre>

          <p style="color: var(--color-text-muted);">
            Swap <code class="code-inline">button</code> for any component name. The
            registry includes all 32 components plus the tokens.
          </p>
        </div>

        <!-- The one rule -->
        <div class="surface" style="border-left: 4px solid var(--color-primary);">
          <h2 class="h-sub">The one hard rule</h2>
          <p style="margin-top: var(--space-3); color: var(--color-text-muted);">
            Whichever path you choose, import the tokens stylesheet exactly once at
            your app root:
          </p>
          <pre class="code-block" style="margin-top: var(--space-4);"><code><span class="tok-keyword">import</span> <span class="tok-string">"@hopline/ux4g-tokens/styles.css"</span>;</code></pre>
          <p style="margin-top: var(--space-4); color: var(--color-text-muted); font-size: var(--body-2-size);">
            Without it, components render unstyled. With it, everything stays themeable
            from a single set of CSS variables.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(installJsonLd)} />
</Base>
