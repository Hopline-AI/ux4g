---
import "@hopline/ux4g-tokens/styles.css";
import "../styles/site.css";
import "../styles/themes.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "UX4G — community packaging",
  description = "Zero-dependency React components and CSS-variable design tokens for India's UX4G government design system. Unofficial community packaging.",
} = Astro.props;

const fullTitle = title === "UX4G — community packaging" ? title : `${title} · UX4G`;

const nav = [
  { href: "/", label: "Home" },
  { href: "/components", label: "Components" },
  { href: "/foundations", label: "Foundations" },
  { href: "/install", label: "Install" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCurrent = (href: string) => (href === "/" ? path === "/" : path === href || path.startsWith(href + "/"));

const github = "https://github.com/Hopline-AI/ux4g";

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og/ux4g-og.png", Astro.site).href;

// Switchable palettes (the swatch is each theme's AA-deepened primary).
const themes = [
  { id: "violet", name: "Violet", swatch: "#613AF5" },
  { id: "sage", name: "Sage", swatch: "#4F8131" },
  { id: "terracotta", name: "Terracotta", swatch: "#B95834" },
  { id: "clay-gold", name: "Clay Gold", swatch: "#956D38" },
  { id: "amber", name: "Amber", swatch: "#B0611C" },
  { id: "coral", name: "Coral", swatch: "#D2403B" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "@id": "https://ux4g.pages.dev/#software",
      name: "UX4G — Hopline community packaging",
      description:
        "Zero-dependency React components and CSS-variable design tokens for India's UX4G (User Experience for Good Governance) government design system. Unofficial community packaging.",
      url: "https://ux4g.pages.dev/",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Any",
      license: "https://opensource.org/licenses/MIT",
      isAccessibleForFree: true,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      programmingLanguage: ["TypeScript", "CSS", "React"],
      codeRepository: github,
      author: { "@id": "https://hopline.co/#org" },
      publisher: { "@id": "https://hopline.co/#org" },
    },
    {
      "@type": "WebSite",
      "@id": "https://ux4g.pages.dev/#website",
      name: "UX4G — Hopline community packaging",
      url: "https://ux4g.pages.dev/",
      description:
        "Docs and live component showcase for the Hopline community packaging of UX4G, India's government design system.",
      inLanguage: "en",
      publisher: { "@id": "https://hopline.co/#org" },
      about: { "@id": "https://ux4g.pages.dev/#software" },
    },
    {
      "@type": "Organization",
      "@id": "https://hopline.co/#org",
      name: "Hopline",
      url: "https://hopline.co",
      slogan: "We turn vision and ideas into products",
      description: "Hopline is a product studio that turns vision and ideas into products.",
      logo: "https://hopline.co/og/hopline-og.png",
      sameAs: ["https://github.com/Hopline-AI", "https://hopline.co"],
    },
  ],
};
---

<!doctype html>
<html lang="en" data-theme="violet">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Apply the saved palette before paint to avoid a flash of the default theme -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("ux4g-theme");
          if (t) document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta name="theme-color" content="#613AF5" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="text/markdown" href="/llms.txt" title="llms.txt" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="UX4G — Hopline community packaging" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="UX4G — Hopline community packaging" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class="site">
      <header class="site-header">
        <div class="container site-header__inner">
          <a class="wordmark" href="/" aria-label="UX4G home">
            <span class="wordmark__ux">UX</span><span class="wordmark__4g">4G</span>
          </a>

          <div class="site-header__right">
            <div class="theme-switcher" role="group" aria-label="Colour theme">
              {themes.map((t) => (
                <button
                  type="button"
                  class="theme-swatch"
                  data-theme-btn={t.id}
                  style={`--sw: ${t.swatch};`}
                  title={`${t.name} theme`}
                  aria-label={`${t.name} theme`}
                  aria-pressed="false"
                ></button>
              ))}
            </div>

          <nav class="site-nav" aria-label="Primary">
            {nav.map((item) => (
              <a
                class="site-nav__link"
                href={item.href}
                aria-current={isCurrent(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            ))}
            <a class="site-nav__link site-nav__github" href={github} rel="noopener noreferrer" target="_blank">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5a11.5 11.5 0 0 0-3.64 22.42c.57.1.78-.25.78-.55v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.72-1.55-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.24 2.75.12 3.04.74.8 1.18 1.82 1.18 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.79.55A11.5 11.5 0 0 0 12 .5Z"/>
              </svg>
              <span>GitHub</span>
            </a>
          </nav>

          <details class="nav-toggle">
            <summary aria-label="Open menu">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="18" x2="21" y2="18" />
              </svg>
            </summary>
            <nav class="nav-toggle__panel" aria-label="Primary mobile">
              {nav.map((item) => (
                <a
                  class="site-nav__link"
                  href={item.href}
                  aria-current={isCurrent(item.href) ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))}
              <a class="site-nav__link" href={github} rel="noopener noreferrer" target="_blank">GitHub</a>
            </nav>
          </details>
          </div>
        </div>
      </header>

      <main class="site-main" id="main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container site-footer__inner">
          <p>
            Unofficial community packaging · UX4G © NeGD · MeitY ·
            <a href="https://www.ux4g.gov.in/" rel="noopener noreferrer" target="_blank">ux4g.gov.in</a>
          </p>
          <p>
            Maintained by <a href="https://hopline.co" rel="noopener noreferrer" target="_blank">hopline.co</a>
            · <a href={github} rel="noopener noreferrer" target="_blank">Source on GitHub</a>
          </p>
        </div>
      </footer>
    </div>

    <script>
      const KEY = "ux4g-theme";
      const root = document.documentElement;
      const btns = Array.from(document.querySelectorAll("[data-theme-btn]"));
      function apply(theme: string) {
        root.setAttribute("data-theme", theme);
        try {
          localStorage.setItem(KEY, theme);
        } catch (e) {}
        btns.forEach((b) =>
          b.setAttribute("aria-pressed", String(b.getAttribute("data-theme-btn") === theme))
        );
      }
      btns.forEach((b) =>
        b.addEventListener("click", () => apply(b.getAttribute("data-theme-btn") || "violet"))
      );
      apply(root.getAttribute("data-theme") || "violet");
    </script>
  </body>
</html>
