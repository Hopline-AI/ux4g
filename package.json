{
  "name": "ux4g-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:visual": "pnpm build && playwright test -c visual/playwright.config.ts",
    "test:theme": "pnpm build && playwright test -c visual/playwright.docs.config.ts",
    "registry:build": "node scripts/build-registry.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "typescript": "^5.6.0"
  }
}
